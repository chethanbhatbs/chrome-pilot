{
  "manifest_version": 3,
  "name": "TabPilot",
  "version": "1.0.0",
  "description": "A powerful sidebar-based tab and window manager for Chrome",
  "permissions": [
    "tabs",
    "tabGroups",
    "windows",
    "sidePanel",
    "storage",
    "sessions",
    "activeTab"
  ],
  "side_panel": {
    "default_path": "sidepanel/index.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Open TabPilot",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+E",
        "mac": "Command+Shift+E"
      },
      "description": "Toggle TabPilot sidebar"
    }
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https://www.google.com; connect-src 'self'"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["sidepanel/*", "sidepanel/static/*", "icons/*"],
      "matches": ["<all_urls>"]
    }
  ]
}
