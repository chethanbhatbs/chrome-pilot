{
  "manifest_version": 3,
  "name": "TabPilot",
  "version": "1.0.0",
  "description": "Manage all your Chrome windows and tabs from a powerful sidebar",
  "permissions": [
    "tabs",
    "windows",
    "sidePanel",
    "storage",
    "sessions",
    "tabGroups",
    "favicon"
  ],
  "side_panel": {
    "default_path": "sidepanel/index.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "Open TabPilot"
  },
  "commands": {
    "_execute_action": {
      "suggested_key": { "default": "Ctrl+Shift+E", "mac": "Command+Shift+E" },
      "description": "Toggle TabPilot sidebar"
    },
    "search-tabs": {
      "suggested_key": { "default": "Ctrl+Shift+F", "mac": "Command+Shift+F" },
      "description": "Focus tab search"
    },
    "close-duplicates": {
      "suggested_key": { "default": "Ctrl+Shift+D", "mac": "Command+Shift+D" },
      "description": "Close duplicate tabs"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
