{
  "manifest_version": 3,
  "name": "Tab Pilot",
  "version": "1.2.0",
  "description": "A keyboard-first command center for finding, switching, cleaning, and focusing Chrome tabs.",
  "permissions": [
    "tabs",
    "tabGroups",
    "windows",
    "sidePanel",
    "storage",
    "sessions",
    "history",
    "activeTab",
    "scripting",
    "nativeMessaging",
    "idle",
    "alarms"
  ],
  "host_permissions": ["<all_urls>"],
  "side_panel": {
    "default_path": "sidepanel/index.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*", "file:///*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "Open Tab Pilot",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+E",
        "mac": "Command+Shift+E"
      },
      "description": "Toggle Tab Pilot sidebar"
    },
    "open-command-center": {
      "suggested_key": {
        "default": "Ctrl+Shift+K",
        "mac": "Command+Shift+K"
      },
      "description": "Open Tab Pilot command center"
    }
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: http: https: blob:; connect-src 'self'"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["sidepanel/*", "sidepanel/static/**", "icons/*"],
      "matches": ["<all_urls>"]
    }
  ]
}
